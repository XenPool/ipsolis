{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Your Prometheus instance scraping ipSolis at /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "ipsolis-overview",
  "title": "ipSolis — Overview",
  "tags": ["ipsolis"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "Request rate",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "sum(rate(ipsolis_http_requests_total[5m]))",
        "legendFormat": "req/s"
      }],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "decimals": 2}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },
    {
      "id": 2, "type": "stat",
      "title": "Error rate (4xx + 5xx)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "sum(rate(ipsolis_http_requests_total{status_class=~\"4xx|5xx\"}[5m])) / sum(rate(ipsolis_http_requests_total[5m]))",
        "legendFormat": "error %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 2,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.01},
            {"color": "red", "value": 0.05}
          ]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },
    {
      "id": 3, "type": "stat",
      "title": "p95 latency",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "histogram_quantile(0.95, sum by (le) (rate(ipsolis_http_request_duration_seconds_bucket[5m])))",
        "legendFormat": "p95"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 3,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 2}
          ]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },
    {
      "id": 4, "type": "stat",
      "title": "Pending approvals",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "ipsolis_approvals_pending",
        "legendFormat": "pending"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 5},
            {"color": "red", "value": 20}
          ]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Request rate by route",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "sum by (route) (rate(ipsolis_http_requests_total[5m]))",
        "legendFormat": "{{route}}"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 11, "type": "timeseries",
      "title": "Latency percentiles (all routes)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"refId": "P50", "expr": "histogram_quantile(0.50, sum by (le) (rate(ipsolis_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50"},
        {"refId": "P95", "expr": "histogram_quantile(0.95, sum by (le) (rate(ipsolis_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95"},
        {"refId": "P99", "expr": "histogram_quantile(0.99, sum by (le) (rate(ipsolis_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 20, "type": "timeseries",
      "title": "Orders by status",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "ipsolis_orders_in_status",
        "legendFormat": "{{status}}"
      }],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}}
    },
    {
      "id": 21, "type": "timeseries",
      "title": "Asset pool — used / free / busy by definition",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "ipsolis_pool_assets",
        "legendFormat": "{{asset_type}} · {{status}}"
      }],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}}
    },
    {
      "id": 30, "type": "timeseries",
      "title": "Celery queue depth",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{
        "refId": "A",
        "expr": "ipsolis_celery_queue_depth",
        "legendFormat": "{{queue}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 25},
            {"color": "red", "value": 100}
          ]}
        }
      }
    }
  ]
}
