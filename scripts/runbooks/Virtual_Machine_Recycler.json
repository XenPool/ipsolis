{
  "name": "Virtual Machine Recycler",
  "description": "Reinstall of Virtual Machines marked for reinstall",
  "is_active": true,
  "cron_enabled": false,
  "cron_expression": null,
  "skip_if_running": true,
  "steps": [
    {
      "position": 1,
      "step_name": "Read Recycle VMs from Asset Pool",
      "script_module_name": "SQL - Read Recycle VMs from Asset Pool",
      "params_template": {
        "DaysInStatus": "0"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 2,
      "step_name": "XenServer - VM stop (force)",
      "script_module_name": "XenServer - VM stop (force)",
      "params_template": {
        "VMName": "{{RecycleVmName}}"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 3,
      "step_name": "XenServer - VM change boot order (net-cd-disk)",
      "script_module_name": "XenServer - VM change boot order (net-cd-disk)",
      "params_template": {
        "VMName": "{{RecycleVmName}}"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 4,
      "step_name": "SCCM - Delete Device",
      "script_module_name": "SCCM - Delete Device",
      "params_template": {
        "VMName": "{{RecycleVmName}}"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 5,
      "step_name": "AD - Delete Computeraccount",
      "script_module_name": "AD - Delete Computeraccount",
      "params_template": {
        "VMName": "{{RecycleVmName}}"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 6,
      "step_name": "AD - Reset RDP and Admin Permissions",
      "script_module_name": "AD - Reset RDP and Admin Permissions",
      "params_template": {
        "RdpGroupDN": "CN=XenPool-VDI-{{RecycleVmName}}-RDP-Users,OU=VDI,OU=XenPool GmbH,DC=xenpool,DC=local",
        "AdminGroupDN": "CN=XenPool-VDI-{{RecycleVmName}}-ADM-Users,OU=VDI,OU=XenPool GmbH,DC=xenpool,DC=local"
      },
      "is_critical": true,
      "retry_count": 1,
      "timeout_seconds": 180,
      "always_run": false
    },
    {
      "position": 7,
      "step_name": "XenServer - Read MAC and Generate SCCMGuiD",
      "script_module_name": "XenServer - VM Read MAC and Generate SCCMGuiD",
      "params_template": {
        "VMName": "{{RecycleVmName}}"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 8,
      "step_name": "AD - Create Computeraccount",
      "script_module_name": "AD - Create Computeraccount",
      "params_template": {
        "VMName": "{{RecycleVmName}}",
        "OU_DN": "OU=VDI,OU=XenPool GmbH,DC=xenpool,DC=local"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 9,
      "step_name": "SCCM - Import Device And Add Collections",
      "script_module_name": "SCCM - Import Device And Add Collections",
      "params_template": {
        "VMName": "{{RecycleVmName}}",
        "SCCMGuiD": "{{SCCMGuiD}}",
        "MACAddress": "{{MACAddress}}",
        "OSCollectionID": "XEN00016",
        "ResourceIdRetries": "60"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 10,
      "step_name": "XenServer - Start VM and Verify Task Sequence",
      "script_module_name": "XenServer - VM Start and Verify Task Sequence",
      "params_template": {
        "VMName": "{{RecycleVmName}}",
        "TaskSequenceWaitSeconds": "900",
        "TaskSequenceCheckSec": "30"
      },
      "is_critical": true,
      "retry_count": 1,
      "timeout_seconds": 1200,
      "always_run": false
    },
    {
      "position": 11,
      "step_name": "XenServer - VM change boot order (disk-net-cd)",
      "script_module_name": "XenServer - VM change boot order (disk-net-cd)",
      "params_template": {
        "VMName": "{{RecycleVmName}}"
      },
      "is_critical": true,
      "retry_count": 3,
      "timeout_seconds": 120,
      "always_run": false
    },
    {
      "position": 12,
      "step_name": "SCCM - Verify Task Sequence and Set Asset Status",
      "script_module_name": "SCCM - Verify Task Sequence Completion and Finalize Asset",
      "params_template": {
        "VMName": "{{RecycleVmName}}",
        "SCCMResourceID": "{{SCCMResourceID}}",
        "CompletionCheckSec": "60",
        "CompletionWaitSeconds": "10800"
      },
      "is_critical": false,
      "retry_count": 1,
      "timeout_seconds": 11100,
      "always_run": true
    }
  ]
}
