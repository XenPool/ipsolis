# ═══════════════════════════════════════════════════════════════
# Ipsolis – Environment Variables
# Copy this file to .env and adjust the values.
# .env is NOT checked into Git!
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
POSTGRES_DB=ipsolis
POSTGRES_USER=xpuser
POSTGRES_PASSWORD=changeme_secure_password

# ──────────────────────────────────────────
# FastAPI
# ──────────────────────────────────────────
# Secret for session signing – use a random string of 32+ characters
API_SECRET_KEY=changeme_very_secret_key_min_32_chars
# Allowed CORS origins (comma-separated) – set to your production domain
CORS_ORIGINS=https://selfservice.yourcompany.com
# Webhook token for ServiceNow (HMAC signature validation)
WEBHOOK_SECRET_TOKEN=changeme_webhook_secret
# Admin UI password (X-Admin-Key header / login form)
ADMIN_API_KEY=changeme_admin_key_min_32_chars

# Optional: encrypt DB backups at-rest. When set, new backups are written as
# *.sql.gz.enc (AES-256-CBC) and restore decrypts automatically; leave empty to
# keep plaintext .sql.gz backups. Keep this OUTSIDE the database and store it in
# your secret manager — the DB dump contains all app_config credentials, so a
# lost key means encrypted backups are unrecoverable. Must be carried to a fresh
# host before restoring an encrypted backup (see docs/DR-RUNBOOK.md).
BACKUP_ENCRYPTION_KEY=

# Air-gap hardening (optional). The runtime is already air-gapped (the browser
# loads all CSS/JS/fonts from this host). Set to true to ALSO emit a strict
# Content-Security-Policy that blocks any accidental external browser request.
# Leave false if you use an external app_logo_url (the CSP would block it).
CSP_ENABLED=false

# ──────────────────────────────────────────
# Celery
# ──────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ──────────────────────────────────────────
# All other settings (AD, SMTP, vSphere, SCCM, Entra ID)
# are configured through the Admin UI: Admin > Settings
# ──────────────────────────────────────────
